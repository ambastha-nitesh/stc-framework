# Normalize line endings to LF on checkin; checkout uses native EOL on Windows.
# This prevents spurious CRLF diffs and keeps CI (which runs on Linux) consistent
# with local dev on Windows.
* text=auto eol=lf

# Python, YAML, TOML, JSON, Markdown — always LF.
*.py    text eol=lf
*.pyi   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf

# Shell scripts must be LF regardless of platform.
*.sh    text eol=lf
*.bash  text eol=lf

# Windows batch / PowerShell stay CRLF.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Binary artifacts — never touch.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.docx  binary
*.xlsx  binary
*.pptx  binary
*.zip   binary
*.gz    binary
*.tar   binary
*.whl   binary
*.parquet binary
